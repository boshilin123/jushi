APP_ENV=development
SECRET_KEY=change-me

# Docker Compose 内部访问 MySQL 时使用服务名；如果连接本机 MySQL，可改成 127.0.0.1。
MYSQL_HOST=jushi-mysql
MYSQL_PORT=3306
# 数据库名称，需要和 backend/db/init.sql 中的 CREATE DATABASE / USE 保持一致。
MYSQL_DATABASE=jushi
MYSQL_USER=jushi
MYSQL_PASSWORD=jushi_pass

DCE_API_BASE=
DCE_CLUSTER=default
DCE_NAMESPACE=default
DCE_TOKEN=

PORT_LIST_API_BASE=http://jushi-port-list:8091
