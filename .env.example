APP_ENV=production
SECRET_KEY=BlueDot@123

# Docker Compose 内部访问 MySQL 时使用服务名；如果连接本机 MySQL，可改成 127.0.0.1。
MYSQL_HOST=jushi-mysql
MYSQL_PORT=3306
# 数据库名称，需要和 backend/db/init.sql 中的 CREATE DATABASE / USE 保持一致。
MYSQL_DATABASE=jushi
MYSQL_USER=jushi
MYSQL_PASSWORD=jushi_pass

DCE_API_BASE=https://10.11.20.71:31123/apis/kpanda.io/v1alpha1
DCE_CLUSTER=kpanda-global-cluster
DCE_NAMESPACE=algorithm
DCE_TOKEN="eyJhbGciOiJSUzI1NiIsImtpZCI6IkRKVjlBTHRBLXZ4MmtQUC1TQnVGS0dCSWc1cnBfdkxiQVVqM2U3RVByWnMiLCJ0eXAiOiJKV1QifQ.eyJpYXQiOjE3Nzk3MDEzNjksImlzcyI6ImdoaXBwby5pbyIsInN1YiI6ImY5YTUwNmViLTFmMDAtNGFjMi04ZDNmLTIxMmQxOWVkN2FhNyIsInByZWZlcnJlZF91c2VybmFtZSI6ImFkbWluIiwiZ3JvdXBzIjpbXSwiaWQiOiI3MDFkNzAxZC0wZjc0LTQxMDMtYjk4MC0xOTViYTEyNDI2NWQifQ.Qv_VIOMYHVC2srV409OKvKw_H6O3Hfc_656UFVMl--4NtPJxuqJLRqRxx1QLfts_UkfIWBwKZH_G15fbh9NG3O_FbingoLAzRw7oaK6P1CLdz6MJQrHM9tjF0qilHJnCvtLFOFgZsCzwNrCDwn1-LzNETeLI8Ij8sfeRZMIDInv410z0nHLB0RGUv2tTnvtavthdKQeJqo9mjZJ2dpqrRoMu6sbO_qtiDm4pa1uZ4cNpjC5hqSD3Vm0sFFnfgBusbvGRVepsUBj1U-88Tp_AkbQR3UGuHg06BApFFqWqy2cLrY7_fxI20SaP9_-TmZV-AzED7cvZvaygiRePNVZeNQ"

# 可选：停止部署和日志查询可直接走 Kubernetes API；不填时从 DCE_API_BASE/DCE_TOKEN 推导。
K8S_API_BASE=https://10.10.53.71:6443
K8S_TOKEN=

# 资源快照
RESOURCE_SNAPSHOT_ENABLED=true
RESOURCE_SNAPSHOT_MIN_INTERVAL_SECONDS=10
RESOURCE_AUTO_SNAPSHOT_ENABLED=true
RESOURCE_AUTO_SNAPSHOT_INTERVAL_SECONDS=10
RESOURCE_SNAPSHOT_RETENTION_DAYS=7

# 可选：Prometheus 真实显存指标。用于覆盖显存 used/total，运行卡数仍使用 K8s/DCE 资源统计。
PROMETHEUS_BASE_URL=http://192.168.10.227:30435
PROMETHEUS_TOKEN=
PROMETHEUS_TIMEOUT_SECONDS=5
PROMETHEUS_GPU_USAGE_ENABLED=true

# 资源容量估算
# 当环境没有暴露 nvidia.com/gpumem / nvidia.com/gpucores 时，按物理卡数量估算容量。
RESOURCE_CAPACITY_ESTIMATION_ENABLED=true

# 当前青海环境如果是 A10，可保持 24；如果是 A100，可改成 80。
GPU_CARD_MEMORY_GIB=24

# 标准化算力单位，仅用于资源中心容量展示，不代表真实 TFLOPS。
GPU_CARD_COMPUTE_UNITS=100

# 当前环境 4 张物理卡暴露 40 个 vGPU，所以默认 10。
VGPU_PER_GPU=10

# 可选：节点显卡型号兜底映射。节点 label 不完整时使用。
# GPU_MODEL_NODE_MAP={"node-gpu-01":"NVIDIA A10","node-gpu-02":"NVIDIA A10"}
